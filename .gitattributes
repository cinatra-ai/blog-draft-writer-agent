# Trim CI/internal noise from `git archive` exports (GitHub release "Source
# code" archives are produced by git-archive, which honors export-ignore).
# Directory-content rules use the `/**` form: a bare `dir/` pattern does not
# recurse for export-ignore. The slash-less dir rules alongside them drop the
# (otherwise empty) directory entries themselves from the archive. npm tarball
# contents are governed separately by the package.json "files" allowlist.
# Per the org release-artifact standard.
.github export-ignore
.github/** export-ignore
.gitattributes export-ignore
.gitignore export-ignore
extension-kind-gate.mjs export-ignore
tests export-ignore
tests/** export-ignore
**/__tests__ export-ignore
**/__tests__/** export-ignore
*.test.* export-ignore
*.spec.* export-ignore
**/__fixtures__ export-ignore
**/__fixtures__/** export-ignore
**/__snapshots__ export-ignore
**/__snapshots__/** export-ignore
coverage export-ignore
coverage/** export-ignore
vitest.config.* export-ignore
jest.config.* export-ignore
