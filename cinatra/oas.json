      "packageName": "@cinatra-ai/blog-draft-writer-agent",
      "hitlScreens": [
        "@cinatra-ai/context-selection-agent:context-selector"
      ],
      "llm": {
        "preferredProvider": "openai",
        "preferredModel": "gpt-5.5"
      },
      "contextSlots": [
        {
          "slotId": "draftContext",
          "acceptedArtifactExtensions": [
            "@cinatra-ai/brand-voice-artifact",
            "@cinatra-ai/blog-idea-artifact"
          ],
          "selectionMode": "interactive",
          "resolutionMode": "accumulate",
          "minItems": 0,
          "maxItems": 5
        }
      ],
      "produces": [
        {
          "extension": "@cinatra-ai/blog-post-artifact"
        }
      ]
    }
  },
