{
  "agentspec_version": "26.1.0",
  "component_type": "Flow",
  "id": "blog-draft-writer-agent-flow",
  "name": "Blog Draft Writer Agent",
  "description": "Stateless LLM-only leaf agent that takes a BlogIdea (title, summary, outline) plus optional tone, length, audience, voice, referenceContent, and sources, and returns a polished markdown blog draft with title, excerpt, content, and optional sourcesUsed. No HITL, no tool calls, no web_search \u2014 pure LLM generation. Caller chains web-research-agent upstream if research is needed.",
  "metadata": {
